{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mexboard",
  "version": "1.25.0",
  "identifier": "com.mexboard",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Mexboard",
        "width": 400,
        "maxWidth": 1000,
        "height": 600,
        "visible": false,
        "skipTaskbar": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["mexboard"]
      }
    },
    "cli": {
      "description": "Mexboard CLI",
      "subcommands": {
        "show": {
          "args": [
            {
              "name": "tab",
              "description": "Tab to show (clipboards, symbols, emojis)",
              "short": "t",
              "takesValue": true,
              "possibleValues": ["clipboards", "symbols", "emojis"]
            },
            {
              "name": "no-default-features",
              "description": "Do nothing"
            },
            {
              "name": "color",
              "takesValue": true,
              "description": "Do nothing"
            }
          ]
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
